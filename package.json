{
  "name": "vikarsystem",
  "version": "1.0.0",
  "description": "System til afdækning af vikarer til folkeskoler",
  "main": "backend/server.js",
  "scripts": {
  "start": "node backend/server.js",
  "dev": "concurrently \"nodemon backend/server.js\" \"npm run dev:frontend\"",
  "dev:backend": "nodemon backend/server.js",
  "dev:frontend": "npm run dev --prefix frontend"
},
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.0"
  }
}
